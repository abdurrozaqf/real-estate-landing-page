{
  "name": "real-estate-landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "start": "next start",
    "lint": "eslint .",
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "deploy": "npm run build && opennextjs-cloudflare deploy",
    "upload": "npm run build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@reduxjs/toolkit": "^2.2.1",
    "@tailwindcss/postcss": "^4.3.2",
    "antd": "^5.14.2",
    "framer-motion": "^11.0.6",
    "next": "15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.0.1",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "wrangler": "^4.105.0"
  }
}
